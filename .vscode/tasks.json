{
    "version": "2.0.0",
    "tasks": [
      {
        "label": "build and run c++20",
        "type": "shell",
        "command": "g++-14",
        "args": [
          "-std=c++20",
          "${file}",
          "-o",
          "${fileDirname}/${fileBasenameNoExtension}"
        ],
        "group": {
          "kind": "build",
          "isDefault": true
        },
        "problemMatcher": ["$gcc"]
      }
    ]
  }
  